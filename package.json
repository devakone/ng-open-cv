{
  "name": "ng-open-cv-lib",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production --base-href \"https://devakone.github.io/ng-open-cv/\"",
    "publish-site": "npm run build && npx ngh --dir=dist/ng-open-cv-lib",
    "test": "ng test",
    "test:ci": "ng test ng-open-cv-lib --configuration=ci",
    "test:lib:ci": "ng test ng-open-cv --configuration=ci",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "build-lib": "ng build ng-open-cv",
    "ci": "npm run build-lib && npm run test:ci && npm run test:lib:ci",
    "build-lib-publish-site": "npm run package && npm run publish-site",
    "copy-lib-assets": "cp-cli projects/ng-open-cv/src/lib/assets dist/ng-open-cv/lib/assets",
    "copy-license": "cp LICENSE dist/ng-open-cv/",
    "copy-readme": "cp README.md dist/ng-open-cv/",
    "copy-files": "npm run copy-license && npm run copy-readme && npm run copy-lib-assets",
    "npm_pack": "cd dist/ng-open-cv && npm pack",
    "package": "npm run build-lib && npm run copy-files && npm run npm_pack"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.15",
    "@angular/common": "^21.2.15",
    "@angular/compiler": "^21.2.15",
    "@angular/core": "^21.2.15",
    "@angular/forms": "^21.2.15",
    "@angular/platform-browser": "^21.2.15",
    "@angular/platform-browser-dynamic": "^21.2.15",
    "@angular/router": "^21.2.15",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.13",
    "@angular/cli": "^21.2.13",
    "@angular/compiler-cli": "^21.2.15",
    "@angular/language-service": "^21.2.15",
    "@angular/build": "^21.2.13",
    "@types/jasmine": "^6.0.0",
    "@types/node": "^25.9.1",
    "angular-cli-ghpages": "^3.0.0",
    "cp-cli": "^1.1.2",
    "jasmine-core": "^6.2.0",
    "jasmine-spec-reporter": "^7.0.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "ng-packagr": "^21.2.5",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
